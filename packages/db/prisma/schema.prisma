generator client {
  provider            = "prisma-client"
  output              = "../generated/prisma"
  importFileExtension = "js"
}

datasource db {
  provider = "postgresql"
}

enum Status {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum Condition {
  NEW
  REFURBISHED
  USED_LIKE_NEW
  USED_GOOD
  USED_FAIR
}

enum OrganizationStatus {
  ACTIVE
  SUSPENDED
}

enum OrganizationPlan {
  BASIC
  ENTERPRISE
}

model Address {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String   @db.Uuid
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name      String
  phone     String
  line1     String
  line2     String?
  region    String
  town      String
  latitude  Float?
  longitude Float?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  isDefault Boolean  @default(false)

  @@map("address")
}

model User {
  id                 String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name               String
  phone              String?
  dob                DateTime? @db.Date
  email              String
  emailVerified      Boolean   @default(false)
  getMarketingEmails Boolean   @default(true)
  getSecurityEmails  Boolean   @default(true)
  getOrderEmails     Boolean   @default(true)
  image              String?
  role               String    @default("user")
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  banned     Boolean?  @default(false)
  banReason  String?
  banExpires DateTime?

  addresses   Address[]
  cart        Cart?
  orders      Order[]
  reviews     Review[]
  sessions    Session[]
  accounts    Account[]
  members     Member[]
  invitations Invitation[]

  @@unique([email])
  @@map("user")
}

model Brand {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name        String    @unique
  slug        String    @unique
  website     String?
  logo        String?
  description String?
  products    Product[]
  status      Status    @default(DRAFT)
  isFeatured  Boolean   @default(false)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @default(now()) @updatedAt

  @@map("brand")
}

model Category {
  id              String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name            String
  slug            String     @unique
  description     String?
  image           String?
  products        Product[]
  parent          Category?  @relation("CategoriesHierarchy", fields: [parentId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  parentId        String?    @db.Uuid
  childCategories Category[] @relation("CategoriesHierarchy")
  status          Status     @default(DRAFT)
  isFeatured      Boolean    @default(false)
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @default(now()) @updatedAt

  @@map("category")
}

model Product {
  id             String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name           String
  slug           String       @unique
  brandId        String       @db.Uuid
  brand          Brand        @relation(fields: [brandId], references: [id])
  organizationId String       @db.Uuid
  organization   Organization @relation(fields: [organizationId], references: [id])

  // Base prices - can be overridden by variants
  basePrice    Decimal @default(0) @db.Decimal(12, 2)
  baseBuyPrice Decimal @default(0) @db.Decimal(12, 2)

  // Stock for products WITHOUT variants
  stock             Int? // Make nullable
  lowStockThreshold Int? // Make nullable
  inStock           Boolean @default(true)

  trackInventory Boolean    @default(true)
  categories     Category[]
  status         Status     @default(DRAFT)
  condition      Condition  @default(NEW)
  description    String?
  images         String[] // Main product images
  rating         Decimal    @default(0) @db.Decimal(12, 2)
  numReviews     Int        @default(0)
  isFeatured     Boolean    @default(false)
  banner         String?

  // Variant support
  hasVariants    Boolean          @default(false)
  variants       ProductVariant[]
  variantOptions VariantOption[] // e.g., "Size", "Color"

  orderItems OrderItem[]
  cartItems  CartItem[]
  reviews    Review[]
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @default(now()) @updatedAt

  @@map("product")
}

// Defines variant types (e.g., "Size", "Color")
model VariantOption {
  id        String               @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  productId String               @db.Uuid
  product   Product              @relation(fields: [productId], references: [id], onDelete: Cascade)
  name      String // e.g., "Size", "Color", "Material"
  position  Int                  @default(0) // Display order
  values    VariantOptionValue[]
  createdAt DateTime             @default(now())
  updatedAt DateTime             @default(now()) @updatedAt

  @@unique([productId, name])
  @@map("variant_option")
}

// Defines specific values (e.g., "Red", "Large", "Cotton")
model VariantOptionValue {
  id            String                @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  optionId      String                @db.Uuid
  option        VariantOption         @relation(fields: [optionId], references: [id], onDelete: Cascade)
  value         String // e.g., "Red", "Large", "XL"
  position      Int                   @default(0)
  variantValues ProductVariantValue[]
  createdAt     DateTime              @default(now())
  updatedAt     DateTime              @default(now()) @updatedAt

  @@unique([optionId, value])
  @@map("variant_option_value")
}

// Individual product variants (e.g., "Red T-Shirt - Size L")
model ProductVariant {
  id        String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  productId String  @db.Uuid
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  // Variant identification
  sku     String  @unique // e.g., "TSHIRT-RED-L"
  barcode String? @unique

  // Variant-specific attributes
  variantValues ProductVariantValue[] // Links to option values (e.g., Color: Red, Size: L)

  // Pricing (overrides product base price if set)
  buyPrice       Decimal? @db.Decimal(12, 2)
  sellPrice      Decimal? @db.Decimal(12, 2)
  compareAtPrice Decimal? @db.Decimal(12, 2) // Original price for discounts

  // Inventory
  stock             Int     @default(0)
  lowStockThreshold Int     @default(5)
  inStock           Boolean @default(true)

  // Variant-specific details
  images     String[] // Variant-specific images
  weight     Decimal? @db.Decimal(12, 2) // For shipping
  dimensions String? // e.g., "10x5x3 cm"

  // Status
  isActive Boolean @default(true)
  position Int     @default(0) // Display order

  orderItems OrderItem[]
  cartItems  CartItem[]
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @default(now()) @updatedAt

  @@map("product_variant")
}

// Junction table linking variants to their option values
model ProductVariantValue {
  id            String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  variantId     String             @db.Uuid
  variant       ProductVariant     @relation(fields: [variantId], references: [id], onDelete: Cascade)
  optionValueId String             @db.Uuid
  optionValue   VariantOptionValue @relation(fields: [optionValueId], references: [id], onDelete: Cascade)

  @@unique([variantId, optionValueId])
  @@map("product_variant_value")
}

model CartItem {
  id        String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  cartId    String          @db.Uuid
  cart      Cart            @relation(fields: [cartId], references: [id], onDelete: Cascade)
  productId String          @db.Uuid
  product   Product         @relation(fields: [productId], references: [id], onDelete: Cascade)
  variantId String?         @db.Uuid
  variant   ProductVariant? @relation(fields: [variantId], references: [id], onDelete: Cascade)
  quantity  Int             @default(1)
  createdAt DateTime        @default(now())
  updatedAt DateTime        @default(now()) @updatedAt

  @@unique([cartId, productId, variantId])
  @@map("cart_item")
}

model Cart {
  id            String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId        String?    @unique @db.Uuid
  sessionCartId String     @unique
  user          User?      @relation(fields: [userId], references: [id], onDelete: Cascade)
  items         CartItem[]
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @default(now()) @updatedAt

  @@map("cart")
}

model Order {
  id              String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId          String      @db.Uuid
  shippingAddress Json        @db.Json
  paymentMethod   String
  paymentResult   Json?       @db.Json
  itemsPrice      Decimal     @db.Decimal(12, 2)
  shippingPrice   Decimal     @db.Decimal(12, 2)
  taxPrice        Decimal     @db.Decimal(12, 2)
  totalPrice      Decimal     @db.Decimal(12, 2)
  isPaid          Boolean     @default(false)
  paidAt          DateTime?   @db.Timestamp(6)
  isDelivered     Boolean     @default(false)
  deliveredAt     DateTime?   @db.Timestamp(6)
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  user            User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  orderitems      OrderItem[]

  @@map("order")
}

model OrderItem {
  id        String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orderId   String @db.Uuid
  productId String @db.Uuid

  // Variant support - optional for products with variants
  variantId String?         @db.Uuid
  variant   ProductVariant? @relation(fields: [variantId], references: [id], onDelete: Cascade)

  qty   Int
  price Decimal @db.Decimal(12, 2)

  // Snapshot data (captured at order time)
  name               String
  slug               String
  image              String
  variantDescription String? // e.g., "Color: Red, Size: Large"
  sku                String? // Captured variant SKU

  order   Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@map("order_item")
}

model Review {
  id                 String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId             String   @db.Uuid
  productId          String   @db.Uuid
  rating             Int
  title              String
  description        String
  isVerifiedPurchase Boolean  @default(true)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  product            Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  user               User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, productId])
  @@map("review")
}

model Session {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  expiresAt DateTime
  token     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String   @db.Uuid
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  impersonatedBy       String?
  activeOrganizationId String?

  @@unique([token])
  @@index([userId])
  @@map("session")
}

model Account {
  id                    String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  accountId             String
  providerId            String
  userId                String    @db.Uuid
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@index([userId])
  @@map("account")
}

model Verification {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
  @@map("verification")
}

model Organization {
  id          String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name        String
  slug        String
  logo        String?
  plan        OrganizationPlan   @default(BASIC)
  status      OrganizationStatus @default(ACTIVE)
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
  metadata    String?
  members     Member[]
  invitations Invitation[]
  products    Product[]

  @@unique([slug])
  @@map("store")
}

model Member {
  id             String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId String       @db.Uuid
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  userId         String       @db.Uuid
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  role           String       @default("member")
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@index([organizationId])
  @@index([userId])
  @@map("store_member")
}

model Invitation {
  id             String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId String       @db.Uuid
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  email          String
  role           String?
  status         String       @default("pending")
  expiresAt      DateTime
  createdAt      DateTime     @default(now())
  inviterId      String       @db.Uuid
  inviter        User         @relation(fields: [inviterId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([email])
  @@map("store_invitation")
}
